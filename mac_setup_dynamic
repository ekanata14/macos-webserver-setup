cat << 'EOF' > reinstall_mac_stack_dynamic.sh
#!/bin/bash
set -e

# Meminta akses sudo di awal untuk digunakan pada tahap permission
sudo -v

GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo -e "${BLUE}=== Memulai Setup macOS PHP Stack & Multi-PHP ===${NC}"

# 1. Cek & Install Homebrew
if ! command -v brew &> /dev/null; then
    echo -e "${BLUE}[1/9] Menginstal Homebrew...${NC}"
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
    if [[ $(uname -m) == 'arm64' ]]; then
        (echo; echo 'eval "$(/opt/homebrew/bin/brew shellenv)"') >> /Users/$USER/.zprofile
        eval "$(/opt/homebrew/bin/brew shellenv)"
    fi
else
    echo -e "${GREEN}[1/9] Homebrew sudah terinstall.${NC}"
fi

brew update

# 2. Install Semua Versi PHP
echo -e "${BLUE}[2/9] Menginstal Seluruh Versi PHP (7.4 - 8.4)...${NC}"
echo -e "${YELLOW}Proses ini mungkin memakan waktu agak lama.${NC}"
brew tap shivammathur/php

# Array versi PHP yang akan diinstal
PHP_VERSIONS=("7.4" "8.0" "8.1" "8.2" "8.3" "8.4")

for version in "${PHP_VERSIONS[@]}"; do
    # Install jika belum ada
    if ! brew list php@$version &> /dev/null; then
        echo "Menginstal PHP $version..."
        brew install shivammathur/php/php@$version
    else
        echo "PHP $version sudah terinstal."
    fi
done

# Matikan semua service PHP agar tidak bentrok port 9000
echo "Memastikan semua service PHP mati sebelum diatur..."
brew services list | grep php | awk '{print $1}' | xargs -I{} brew services stop {} 2>/dev/null || true

# Jadikan PHP 8.4 sebagai default awal
brew unlink php &>/dev/null || true
for version in "${PHP_VERSIONS[@]}"; do
    brew unlink php@$version &>/dev/null || true
done
brew link --overwrite --force php@8.4
brew services start php@8.4

# 3. Menambahkan Fungsi switch-php ke ~/.zshrc
echo -e "${BLUE}[3/9] Membuat command 'switch-php' di ~/.zshrc...${NC}"
# Hapus blok fungsi lama jika sudah pernah dibuat
sed -i '' '/# START PHP SWITCHER/,/# END PHP SWITCHER/d' ~/.zshrc

cat << 'ZSHRC_FUNC' >> ~/.zshrc
# START PHP SWITCHER
switch-php() {
    if [ -z "\$1" ]; then
        echo "Gunakan: switch-php <versi>"
        echo "Contoh : switch-php 8.2"
        return 1
    fi
    
    TARGET_PHP="php@\$1"
    
    # Validasi apakah versi PHP terinstal di brew
    if ! brew list "\$TARGET_PHP" &> /dev/null; then
        echo "Error: \$TARGET_PHP belum terinstal via Homebrew."
        return 1
    fi

    echo "Beralih ke PHP \$1..."
    
    # 1. Hentikan semua layanan PHP yang sedang berjalan
    brew services list | grep php | awk '{print \$1}' | xargs -I{} brew services stop {} 2>/dev/null
    
    # 2. Unlink semua versi PHP
    brew list | grep php | xargs -I{} brew unlink {} 2>/dev/null
    
    # 3. Link versi yang dipilih
    brew link --overwrite --force "\$TARGET_PHP"
    
    # 4. Jalankan service PHP yang dipilih (otomatis menggunakan port 9000)
    brew services start "\$TARGET_PHP"
    
    # 5. Restart Nginx
    brew services restart nginx
    
    echo "====================================="
    echo "Berhasil beralih versi!"
    php -v
    echo "====================================="
}
# END PHP SWITCHER
ZSHRC_FUNC

# 4. Install Nginx & Konfigurasi
echo -e "${BLUE}[4/9] Menginstal Nginx...${NC}"
brew install nginx
BREW_PREFIX=$(brew --prefix)
WEB_ROOT="$HOME/nginx-server"
mkdir -p "$WEB_ROOT"

echo -e "${BLUE}[INFO] Membuat konfigurasi Nginx PHP dinamis...${NC}"
mkdir -p "$BREW_PREFIX/etc/nginx/servers"

cat <<NGINX_CONF > "$BREW_PREFIX/etc/nginx/servers/native-stack.conf"
server {
    listen 8080;
    server_name localhost;
    root $WEB_ROOT;

    autoindex on;
    autoindex_exact_size off;
    autoindex_localtime on;

    index index.php index.html index.htm;

    location / {
        try_files \$uri \$uri/ =404;
    }

    location ~ \.php$ {
        fastcgi_pass 127.0.0.1:9000;
        fastcgi_index index.php;
        fastcgi_param SCRIPT_FILENAME \$document_root\$fastcgi_script_name;
        include fastcgi_params;
    }
}
NGINX_CONF

brew services restart nginx

# 5. Install MySQL
echo -e "${BLUE}[5/9] Menginstal MySQL...${NC}"
brew install mysql
brew services start mysql 2>/dev/null || true

# 6. Install NVM
echo -e "${BLUE}[6/9] Menginstal NVM...${NC}"
brew install nvm
mkdir -p ~/.nvm
if ! grep -q "nvm.sh" ~/.zshrc; then
  echo 'export NVM_DIR="$HOME/.nvm"' >> ~/.zshrc
  echo "[ -s \"$BREW_PREFIX/opt/nvm/nvm.sh\" ] && \. \"$BREW_PREFIX/opt/nvm/nvm.sh\"" >> ~/.zshrc
  echo "[ -s \"$BREW_PREFIX/opt/nvm/etc/bash_completion.d/nvm\" ] && \. \"$BREW_PREFIX/opt/nvm/etc/bash_completion.d/nvm\"" >> ~/.zshrc
fi
export NVM_DIR="$HOME/.nvm"
[ -s "$BREW_PREFIX/opt/nvm/nvm.sh" ] && \. "$BREW_PREFIX/opt/nvm/nvm.sh"
nvm install node

# 7. Install Composer
echo -e "${BLUE}[7/9] Menginstal Composer...${NC}"
brew install composer

# 8. Install phpMyAdmin
echo -e "${BLUE}[8/9] Menginstal phpMyAdmin...${NC}"
PMA_VER="5.2.1"
cd /tmp
curl -O -L https://files.phpmyadmin.net/phpMyAdmin/${PMA_VER}/phpMyAdmin-${PMA_VER}-all-languages.zip
unzip -q phpMyAdmin-${PMA_VER}-all-languages.zip
rm -rf "$WEB_ROOT/phpmyadmin"
mv phpMyAdmin-${PMA_VER}-all-languages "$WEB_ROOT/phpmyadmin"
rm phpMyAdmin-${PMA_VER}-all-languages.zip

cp "$WEB_ROOT/phpmyadmin/config.sample.inc.php" "$WEB_ROOT/phpmyadmin/config.inc.php"
RANDOM_SECRET=$(openssl rand -base64 32)
sed -i '' "s/\['blowfish_secret'\] = '';/\['blowfish_secret'\] = '$RANDOM_SECRET';/" "$WEB_ROOT/phpmyadmin/config.inc.php"
sed -i '' "s/\['AllowNoPassword'\] = false;/\['AllowNoPassword'\] = true;/" "$WEB_ROOT/phpmyadmin/config.inc.php"

# 9. Set Permissions Ekstrem (Menggunakan Sudo)
echo -e "${BLUE}[9/9] Menerapkan Super Permission untuk menghindari Forbidden...${NC}"
# Pastikan folder dimiliki oleh user saat ini
sudo chown -R $USER "$WEB_ROOT"
# Berikan izin eksekusi dan baca yang luas pada folder root
sudo chmod -R 755 "$WEB_ROOT"
# Berikan hak akses eksekusi ke folder Users/username agar Nginx bisa menembus
sudo chmod a+x "$HOME"

echo "<?php phpinfo(); ?>" > "$WEB_ROOT/info.php"

echo "------------------------------------------------"
echo -e "${GREEN}Instalasi Selesai!${NC}"
echo "------------------------------------------------"
echo "Web Root         : $WEB_ROOT"
echo "------------------------------------------------"
echo "Cek PHP          : http://localhost:8080/info.php"
echo "phpMyAdmin       : http://localhost:8080/phpmyadmin"
echo "------------------------------------------------"
echo -e "${YELLOW}PENTING: Jalankan perintah ini sekarang agar fungsi switch-php aktif:${NC}"
echo -e "${GREEN}source ~/.zshrc${NC}"
EOF

chmod +x reinstall_mac_stack_dynamic.sh && ./reinstall_mac_stack_dynamic.sh
